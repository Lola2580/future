<!doctypehtml><meta charset=UTF-8><meta content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"name=viewport><title>LOGICLESS PREDICTOR</title><link href=main.css rel=stylesheet><script src=https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.39.7/dist/umd/supabase.min.js></script><div id=mainPage><div class=header><h1>🧠 LOGICLESS PREDICTOR</h1><div class=user-info><span id=userName>Guest</span></div></div><div class=game-selector><button class="game-btn active"onclick='switchGame("30s")'data-game=30s>30 Sec</button> <button class=game-btn onclick='switchGame("1m")'data-game=1m>1 Min</button> <button class=game-btn onclick='switchGame("3m")'data-game=3m>3 Min</button> <button class=game-btn onclick='switchGame("5m")'data-game=5m>5 Min</button></div><div class=predictor-box><div class=timer-row><span id=timer>--</span> <span id=gameLabel>WinGo 30 Seconds</span></div><div class=prediction-row><span class=label>Prediction:</span><div class=prediction-circles id=predictionNumbers><span class=no-data>No Trade</span></div><label class=beep-label><input id=beepToggle checked type=checkbox> 🔊 Beep</label></div><audio id=beepSound src=https://www.soundjay.com/buttons/sounds/beep-07.mp3></audio></div><div class=box><h2>📊 Latest Results</h2><div class=table-wrapper><table><thead><tr><th>Period<th>Number<th>Big/Small<tbody id=liveResults></table></div></div><div class=box><h2>🔍 Manual Search</h2><div class=search-row><input id=manualSeq class=search maxlength=5 placeholder="Enter 5-digit sequence"> <button class=search-btn onclick=manualSearch()>Search</button></div><div id=manualResult></div></div></div><script src=main.js></script>
